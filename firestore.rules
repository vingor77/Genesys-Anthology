rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.dmId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.dmId == request.auth.uid;
    }

    match /memberships/{membershipId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null &&
        (request.auth.uid == resource.data.uid ||
         get(/databases/$(database)/documents/sessions/$(resource.data.sessionId)).data.dmId == request.auth.uid);
    }

    match /characters/{characterId} {
      allow read: if request.auth != null &&
        (resource.data.uid == request.auth.uid ||
         get(/databases/$(database)/documents/sessions/$(resource.data.sessionId)).data.dmId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.uid == request.auth.uid;
    }

    match /objects/{objectId} {
      allow read: if request.auth != null &&
        (!('sessionId' in resource.data) ||
         resource.data.sessionId == null ||
         get(/databases/$(database)/documents/sessions/$(resource.data.sessionId)).data.dmId == request.auth.uid ||
         resource.data.ownerId == request.auth.uid);
      allow create: if request.auth != null &&
        (!('sessionId' in request.resource.data) ||
         request.resource.data.ownerId == request.auth.uid);
      allow update: if request.auth != null &&
        (!('sessionId' in resource.data) ||
         resource.data.ownerId == request.auth.uid);
    }

    match /qualities/{qualityId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null; // seed page writes here — no formal admin role yet, same accepted gap as objects' global catalog
    }
    match /skills/{skillId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /talents/{talentId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /criticalInjuries/{injuryId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    match /keywords/{keywordId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}